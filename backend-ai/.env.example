# ── Supabase ──────────────────────────────────────────────────────────────────
# Use the SERVICE ROLE key (bypasses RLS for backend writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ── Fonnte (WhatsApp) ─────────────────────────────────────────────────────────
FONNTE_TOKEN=your-fonnte-token-here
# Set to "true" to skip actual WA sends (log only) — useful for local dev
FONNTE_DRY_RUN=true

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Path to a service account JSON file with Sheets read access
# If not set, the ingestion layer falls back to CSV mode
GOOGLE_SA_JSON_PATH=

# ── Pipeline config ───────────────────────────────────────────────────────────
# Cron schedule (APScheduler cron format) — default: 23:00 WIB = 16:00 UTC
CRON_HOUR_UTC=16
CRON_MINUTE_UTC=0

# Max active SKUs per owner processed in one run
MAX_ACTIVE_SKUS=20

# Active window: SKUs must have sold in last N days to be considered "active"
ACTIVE_WINDOW_DAYS=30

# Test window (hold-out days for MAPE evaluation)
TEST_DAYS=30

# MAPE threshold above which Prophet triggers ARIMA fallback
PROPHET_FALLBACK_MAPE_THRESH=0.40

# ── Local dev ─────────────────────────────────────────────────────────────────
# If set, pipeline.run_owner() will use this CSV instead of fetching Sheets
DEV_CSV_PATH=
# If set, skip Supabase reads/writes (print payload to stdout only)
DEV_MODE=false
